# ClawEx environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Choose: "anthropic" or "openai"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-5

# Anthropic Claude (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (https://platform.openai.com/api-keys) — only if LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here

# ─── Channels ──────────────────────────────────────────────────────────────────
# Telegram Bot API token (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# WhatsApp (Meta Cloud API — https://developers.facebook.com/apps)
# 1. Create App → Business → Add WhatsApp product
# 2. webhook URL: https://your-domain.com/api/webhooks/whatsapp
# 3. Subscribe to: messages
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_VERIFY_TOKEN=your_secret_webhook_verify_token

# ─── Phoenix ──────────────────────────────────────────────────────────────────
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=your_64_char_secret_here
PORT=4000

# ─── External Services ─────────────────────────────────────────────────────────
# Node.js Playwright browser service (Tier 2)
BROWSER_SERVICE_URL=http://localhost:4001

# Python AI/RAG service (Tier 3, optional)
AI_SERVICE_URL=http://localhost:5001

# ─── BEAM Clustering (optional) ────────────────────────────────────────────────
# Set to true to enable multi-node clustering via libcluster
CLUSTER_ENABLED=false
# Strategy: gossip (LAN multicast), dns (Kubernetes/Fly.io), epmd (explicit hosts)
CLUSTER_STRATEGY=gossip
# DNS mode only:
# CLUSTER_DNS_NAME=claw-ex.internal
# CLUSTER_HOSTS=claw_ex@node1.example.com,claw_ex@node2.example.com


